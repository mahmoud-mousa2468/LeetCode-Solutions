/**
 * Problem: 4. Richest Customer Wealth
 * Difficulty: Easy
 * Link: https://leetcode.com/problems/richest-customer-wealth/
 * * Strategy: Iteration & Accumulation
 */

var maximumWealth = function(accounts) {
    let theRichest=0
    for(let i=0;i<accounts.length;i++){
        let currentCustomerWealth=0
      for(let j=0;j<accounts[i].length;j++){
        currentCustomerWealth+=accounts[i][j]
      }
      theRichest=Math.max(theRichest,currentCustomerWealth)
    }
    return theRichest
};

// Time Complexity: O(m * n) - where m is number of customers and n is number of banks.
// Space Complexity: O(1)
